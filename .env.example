# Browser-safe API base path. Keep the same-origin proxy for local/self-hosted runs.
NEXT_PUBLIC_OBSERVAI_API_URL=/api/observai

# Server-side ObservAI API target used by app/api/observai/[...path].
OBSERVAI_API_URL=http://localhost:8080

# Browser-safe display/runtime labels.
NEXT_PUBLIC_APP_NAME=ObservAI
NEXT_PUBLIC_APP_ENV=local
